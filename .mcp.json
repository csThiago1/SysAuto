{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://paddock:paddock@localhost:5432/paddock_dev"
      ]
    },
    "redis": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis",
        "redis://localhost:6379"
      ]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "cloudflare": {
      "command": "npx",
      "args": ["-y", "@cloudflare/mcp-server-cloudflare", "run", "SEU_CLOUDFLARE_ACCOUNT_ID"]
    },
    "expo": {
      "command": "npx",
      "args": ["-y", "expo-mcp", "--root", "apps/mobile"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp", "--headless"]
    },
    "sentry": {
      "command": "npx",
      "args": ["-y", "@sentry/mcp-server", "--agent"]
    }
  }
}
