# ─────────────────────────────────────────────────────────────────────────────
# Grupo DS Car — .env.example
# Copie para .env e preencha os valores reais.
# NUNCA commitar o .env com valores reais.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Banco de dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://paddock:paddock@localhost:5432/paddock_dev
DATABASE_PUBLIC_SCHEMA=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CHANNEL_LAYERS_URL=redis://localhost:6379/2

# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production-use-django-get-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.paddock.solutions

# ─── Keycloak / OIDC ─────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=paddock
KEYCLOAK_CLIENT_ID=paddock-backend
KEYCLOAK_CLIENT_SECRET=change-me
OIDC_OP_JWKS_ENDPOINT=http://localhost:8080/realms/paddock/protocol/openid-connect/certs
OIDC_OP_AUTHORIZATION_ENDPOINT=http://localhost:8080/realms/paddock/protocol/openid-connect/auth
OIDC_OP_TOKEN_ENDPOINT=http://localhost:8080/realms/paddock/protocol/openid-connect/token
OIDC_OP_USER_ENDPOINT=http://localhost:8080/realms/paddock/protocol/openid-connect/userinfo

# ─── IA — Claude API ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── WhatsApp — Evolution API ────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=dscar

# ─── Consulta de placa ───────────────────────────────────────────────────────
SIEVE_API_KEY=change-me

# ─── Fiscal ──────────────────────────────────────────────────────────────────
SEFAZ_ENV=homologation
DSCAR_CNPJ=00000000000000
DSCAR_CERT_PATH=/path/to/certificate.pfx
DSCAR_CERT_PASSWORD=change-me
FOCUSNFE_TOKEN=change-me

# ─── Pagamentos — Asaas ──────────────────────────────────────────────────────
ASAAS_API_KEY=change-me
ASAAS_ENV=sandbox

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_DEFAULT_REGION=sa-east-1
AWS_S3_BUCKET=paddock-dev-storage
DW_S3_BUCKET=paddock-dev-datalake

# ─── Monitoramento ───────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── Next.js / Frontend ──────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=paddock
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=paddock-frontend
