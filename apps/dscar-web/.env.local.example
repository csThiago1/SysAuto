# ─────────────────────────────────────────────────────────────────────────────
# dscar-web — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA versione o .env.local (já está no .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── next-auth ────────────────────────────────────────────────────────────────

# URL pública do app Next.js. Em desenvolvimento: http://localhost:3001
# Em produção: https://dscar.paddock.solutions
NEXTAUTH_URL=http://localhost:3001

# Segredo usado para assinar os cookies de sessão.
# Gere um valor seguro com: openssl rand -base64 32
# Em produção, use um secret manager (AWS Secrets Manager, Doppler, etc.)
NEXTAUTH_SECRET=troque-por-um-valor-seguro-gerado-com-openssl

# ── Dev-credentials (opcional — apenas em desenvolvimento) ──────────────────

# Secret HS256 para o provider dev-credentials.
# Deve coincidir com DEV_JWT_SECRET do backend Django.
# Senha padrão de login: paddock123
DEV_JWT_SECRET=dscar-dev-secret-paddock-2025

# ── Keycloak (SSO) ────────────────────────────────────────────────────────────

# ID do client registrado no realm Keycloak.
# Realm local: paddock | Client: paddock-frontend
KEYCLOAK_CLIENT_ID=paddock-frontend

# Secret do client Keycloak (aba "Credentials" no console do Keycloak).
# Deixe vazio apenas em desenvolvimento com dev credentials ativado.
KEYCLOAK_CLIENT_SECRET=

# URL base do realm Keycloak.
# Desenvolvimento local (docker-compose): http://localhost:8080/realms/paddock
# Staging/Produção: https://sso.paddock.solutions/realms/paddock
KEYCLOAK_ISSUER=http://localhost:8080/realms/paddock

# ── Tenant padrão (opcional) ────────────────────────────────────────────────

# Fallback quando sessão não tem activeCompany (ex: primeiro carregamento).
# O proxy constrói X-Tenant-Domain como "<activeCompany>.localhost" quando disponível.
DEFAULT_TENANT_DOMAIN=dscar.localhost

# ── API Django (backend) ──────────────────────────────────────────────────────

# URL base da API Django. Usada pelo proxy Next.js (/api/proxy/[...path]).
# O proxy injeta automaticamente o header Host: dscar.localhost para o tenant.
# Desenvolvimento local: http://localhost:8000
# Em produção, o proxy Next.js não é usado — o Nginx roteia diretamente.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# NOTAS DE DESENVOLVIMENTO
#
# Dev credentials (sem Keycloak):
#   - Email: qualquer endereço válido
#   - Senha: paddock123
#   - Token gerado: dev-mock-token (aceito pelo Django em modo DJANGO_DEV_BYPASS_AUTH=true)
#
# Para iniciar o ambiente completo:
#   make dev          (sobe Django + PostgreSQL + Redis + Keycloak via Docker)
#   pnpm dev          (inicia Next.js na porta 3001)
# ─────────────────────────────────────────────────────────────────────────────
